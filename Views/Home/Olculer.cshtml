
@{
    ViewData["Title"] = "Olculer";
}

<div class="container mt-5">

    <h1 class="text-center mb-4">📏 Türk Bayrağının Ölçüleri</h1>

    <div class="card shadow p-4">

        <p>
            Türk bayrağı gelişigüzel çizilmez. Ölçüleri kanunla belirlenmiştir ve
            her detay matematiksel oranlara göre hesaplanır.
        </p>

        <table class="table table-bordered mt-4">
            <tr>
                <th>Özellik</th>
                <th>Oran</th>
            </tr>
            <tr>
                <td>En / Boy</td>
                <td>2 / 3</td>
            </tr>
            <tr>
                <td>Hilal çapı</td>
                <td>Belirli geometrik oran</td>
            </tr>
            <tr>
                <td>Yıldız konumu</td>
                <td>Merkeze simetrik</td>
            </tr>
        </table>

        <p>
            Bu oranlar sayesinde bayrak her yerde aynı standartta üretilir.
        </p>

        <div class="text-end">
            <a asp-action="Kanun" class="btn btn-dark">Sonraki Sayfa → Kanun</a>
        </div>

    </div>

</div>


