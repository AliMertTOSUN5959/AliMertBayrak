
@{
    ViewData["Title"] = "Anlam";
}

<div class="container mt-5">

    <h1 class="text-center text-danger mb-4">🇹🇷 Türk Bayrağının Anlamı</h1>

    <div class="card shadow p-4">

        <p>
            Türk bayrağı, milletimizin bağımsızlığını, kahramanlığını ve vatan sevgisini temsil eden
            en kutsal sembolümüzdür. Yüzyıllardır özgürlük mücadelesinin simgesi olmuştur.
        </p>

        <h4 class="mt-4 text-danger">🔴 Kırmızı Renk</h4>
        <p>
            Kırmızı renk, vatan uğruna can veren şehitlerimizin kanını temsil eder.
            Aynı zamanda cesaret ve kahramanlığı simgeler.
        </p>

        <h4 class="mt-3 text-danger">⭐ Ay ve Yıldız</h4>
        <p>
            Ay yıldız bağımsızlığı, umudu ve Türk milletinin birliğini ifade eder.
            Tarih boyunca Türk devletlerinin bayraklarında kullanılmıştır.
        </p>

        <div class="text-end mt-4">
            <a asp-action="Olculer" class="btn btn-danger">Sonraki Sayfa → Ölçüler</a>
        </div>

    </div>

</div>


